generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PAID
  FAILED
  REFUNDED
}

enum ProductType {
  COURSE
  BUNDLE
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  SENT
}

enum CourseLevel {
  ALL_LEVELS
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum CategoryColor {
  VIOLET
  BLUE
  EMERALD
  AMBER
  SLATE
}

enum ThumbnailVariant {
  DARK
  BLUE
  PURPLE
  GREEN
}

model Category {
  id            String        @id @default(cuid())
  locale        String
  catalogKey    String
  label         String
  slug          String
  description   String
  color         CategoryColor @default(VIOLET)
  sortOrder     Int           @default(0)
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  courses       Course[]
  bundles       Bundle[]

  @@unique([locale, slug])
  @@index([locale, catalogKey])
  @@index([isActive, sortOrder])
}

model Course {
  id                String           @id @default(cuid())
  locale            String
  catalogKey        String
  categoryId        String
  title             String
  subtitle          String?
  slug              String
  level             CourseLevel
  rating            Decimal          @db.Decimal(3, 2)
  reviews           Int
  price             Decimal          @db.Decimal(10, 2)
  regularPrice      Decimal          @db.Decimal(10, 2)
  currency          String
  durationHours     Int
  lessons           Int
  highlights        Json
  outcomes          Json
  agenda            Json
  udemyCourseId     String?
  udemyUrl          String?
  thumbnailImageUrl String?
  trailerYoutubeUrl String?
  isBestseller      Boolean          @default(false)
  sortOrder         Int              @default(0)
  isActive          Boolean          @default(true)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  category          Category         @relation(fields: [categoryId], references: [id])
  bundleCourses     BundleCourse[]

  @@unique([locale, slug])
  @@index([locale, catalogKey])
  @@index([udemyCourseId])
  @@index([categoryId])
  @@index([isActive, sortOrder])
}

model Bundle {
  id                String           @id @default(cuid())
  locale            String
  catalogKey        String
  categoryId        String
  title             String
  subtitle          String?
  slug              String
  description       String
  courseCount       Int
  rating            Decimal          @db.Decimal(3, 2)
  reviews           Int
  price             Decimal          @db.Decimal(10, 2)
  regularPrice      Decimal          @db.Decimal(10, 2)
  currency          String
  thumbnailTitle    String
  thumbnailSubtitle String
  thumbnailVariant  ThumbnailVariant
  thumbnailImageUrl String?
  sortOrder         Int              @default(0)
  isActive          Boolean          @default(true)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  category          Category         @relation(fields: [categoryId], references: [id])
  courses           BundleCourse[]

  @@unique([locale, slug])
  @@index([locale, catalogKey])
  @@index([categoryId])
  @@index([isActive, sortOrder])
}

model BundleCourse {
  bundleId  String
  courseId  String
  position  Int      @default(0)
  createdAt DateTime @default(now())
  bundle    Bundle   @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@id([bundleId, courseId])
  @@index([courseId])
}

model BlogPost {
  id                String    @id @default(cuid())
  locale            String
  title             String
  slug              String
  excerpt           String
  contentHtml       String
  thumbnailImageUrl String?
  metaTitle         String?
  metaDescription   String?
  metaKeywords      String?
  viewCount         Int       @default(0)
  isPublished       Boolean   @default(false)
  publishedAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([locale, slug])
  @@index([locale, isPublished, publishedAt])
  @@index([updatedAt])
}

model Order {
  id                      String        @id @default(cuid())
  orderNumber             String        @unique
  accessToken             String        @unique
  locale                  String
  currency                String
  status                  OrderStatus   @default(PENDING)
  paymentStatus           PaymentStatus @default(UNPAID)
  regularTotalAmount      Decimal       @db.Decimal(10, 2)
  subtotalAmount          Decimal       @db.Decimal(10, 2)
  discountCode            String?
  discountAmount          Decimal       @default(0) @db.Decimal(10, 2)
  totalAmount             Decimal       @db.Decimal(10, 2)
  customerEmail           String?
  customerName            String?
  stripeCheckoutSessionId String        @unique
  stripePaymentIntentId   String?
  accessEmailSentAt       DateTime?
  accessEmailError        String?
  telegramNotifiedAt      DateTime?
  telegramNotifyError     String?
  paidAt                  DateTime?
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt
  items                   OrderItem[]
  invoice                 Invoice?

  @@index([locale])
  @@index([status])
  @@index([paymentStatus])
  @@index([createdAt])
}

model OrderItem {
  id                String      @id @default(cuid())
  orderId           String
  productId         String
  productType       ProductType
  title             String
  quantity          Int         @default(1)
  regularUnitAmount Decimal     @db.Decimal(10, 2)
  unitAmount        Decimal     @db.Decimal(10, 2)
  lineTotalAmount   Decimal     @db.Decimal(10, 2)
  createdAt         DateTime    @default(now())
  order             Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([productId, productType])
}

model Invoice {
  id                String        @id @default(cuid())
  orderId           String        @unique
  invoiceNumber     String        @unique
  status            InvoiceStatus @default(DRAFT)
  locale            String
  currency          String
  sellerName        String
  sellerAddress     String
  sellerTaxId       String?
  buyerName         String
  buyerCompany      String?
  buyerEmail        String
  buyerCountry      String
  buyerTaxId        String?
  buyerAddressLine1 String
  buyerPostalCode   String
  buyerCity         String
  subtotalAmount    Decimal       @db.Decimal(10, 2)
  discountAmount    Decimal       @default(0) @db.Decimal(10, 2)
  totalAmount       Decimal       @db.Decimal(10, 2)
  issuedAt          DateTime      @default(now())
  pdfUrl            String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  order             Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([issuedAt])
}

model DiscountCode {
  id          String    @id @default(cuid())
  code        String    @unique
  percentage  Int
  description String?
  validFrom   DateTime?
  validUntil  DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([isActive])
  @@index([validUntil])
}

model UdemyCoupon {
  id          String   @id @default(cuid())
  courseId    String
  locale      String   @default("pl")
  courseTitle String?
  udemyUrl    String
  couponCode  String
  validUntil  DateTime
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([courseId, locale, couponCode])
  @@index([courseId, locale, isActive])
  @@index([validUntil])
}
